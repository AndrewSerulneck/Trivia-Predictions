{
  "name": "hightop-challenge",
  "version": "0.1.0",
  "private": true,
  "description": "A mobile website that allows users to compete with each other on trivia and predictions.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "auth:smoke": "node scripts/auth-smoke.cjs",
    "category-blitz:build": "node --env-file=.env.local scripts/build-category-blitz-letter-index.cjs",
    "category-blitz:build:dry-run": "node --env-file=.env.local scripts/build-category-blitz-letter-index.cjs --dry-run",
    "category-blitz:simulate": "node --env-file=.env.local --conditions react-server --import tsx scripts/simulate-category-blitz.cjs",
    "category-blitz:simulate:llm": "node --env-file=.env.local --conditions react-server --import tsx scripts/simulate-category-blitz.cjs --llm",
    "trivia:generate": "node --env-file=.env.local scripts/generate-trivia-questions.cjs",
    "trivia:generate:nightly": "node --env-file=.env.local scripts/generate-trivia-nightly.cjs --total 100",
    "trivia:check": "node scripts/import-trivia-questions.cjs --dir data/trivia/categories --check",
    "trivia:import": "node --env-file=.env.local scripts/import-trivia-questions.cjs --dir data/trivia/categories",
    "trivia:import:prune": "node --env-file=.env.local scripts/import-trivia-questions.cjs --dir data/trivia/categories",
    "trivia:sync": "node --env-file=.env.local scripts/sync-local-trivia.cjs",
    "trivia:sync:dry-run": "node --env-file=.env.local scripts/sync-local-trivia.cjs --dry-run",
    "trivia:duplicates:audit": "node --env-file=.env.local scripts/cleanup-trivia-duplicates.cjs",
    "trivia:duplicates:fix:db": "node --env-file=.env.local scripts/cleanup-trivia-duplicates.cjs --apply-db",
    "trivia:duplicates:fix:local": "node scripts/cleanup-trivia-duplicates.cjs --apply-local",
    "trivia:duplicates:fix": "node --env-file=.env.local scripts/cleanup-trivia-duplicates.cjs --apply-db --apply-local",
    "trivia:bank:check": "node scripts/backfill-trivia-question-bank.cjs --check",
    "trivia:bank:backfill": "node --env-file=.env.local scripts/backfill-trivia-question-bank.cjs",
    "live-trivia:generate": "node --env-file=.env.local scripts/generate-live-trivia-questions.cjs",
    "live-trivia:generate:nightly": "node --env-file=.env.local scripts/generate-live-trivia-nightly.cjs --total 50",
    "live-trivia:check": "node scripts/import-trivia-questions.cjs --live-dir data/live-trivia/categories --check",
    "live-trivia:import": "node --env-file=.env.local scripts/import-trivia-questions.cjs --live-dir data/live-trivia/categories",
    "live-trivia:randomness:audit": "node --conditions react-server --import tsx scripts/audit-live-trivia-randomness.cjs",
    "live-trivia:future-reseed:dry-run": "node --env-file=.env.local --conditions react-server --import tsx scripts/reseed-live-trivia-future.cjs",
    "live-trivia:future-reseed:apply": "node --env-file=.env.local --conditions react-server --import tsx scripts/reseed-live-trivia-future.cjs --apply",
    "headshots:sync": "node scripts/sync-headshots.js",
    "apisports:probe:nba": "node --env-file=.env.local scripts/probe-apisports-nba.cjs",
    "live-showdown:seed": "node --env-file=.env.local --import tsx scripts/seedLiveShowdownPool.ts",
    "trivia:restore-speed": "node --env-file=.env.local scripts/restore-deleted-speed-trivia.cjs",
    "landmark:images": "node --env-file=.env.local scripts/enrich-landmark-images.cjs",
    "landmark:images:dry-run": "node --env-file=.env.local scripts/enrich-landmark-images.cjs --dry-run",
    "landmark:review": "node scripts/review-trivia-images.cjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AndrewSerulneck/Hightop-Challenge.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AndrewSerulneck/Hightop-Challenge/issues"
  },
  "homepage": "https://github.com/AndrewSerulneck/Hightop-Challenge#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@supabase/supabase-js": "^2.95.3",
    "chart.js": "^4.5.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.564.0",
    "next": "^16.1.6",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "stripe": "^22.3.1",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.24",
    "d3-geo": "^3.1.1",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "topojson-client": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "us-atlas": "^3.0.1",
    "vitest": "^4.0.18",
    "world-atlas": "^2.0.2"
  }
}
