NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_DISABLE_GEOFENCE=false
VENUE_PRESENCE_ENFORCEMENT=1
VENUE_PRESENCE_TTL_MS=180000
VENUE_PRESENCE_MIN_RADIUS_METERS=300
VENUE_PRESENCE_ACCURACY_BUFFER_MIN_METERS=120
VENUE_PRESENCE_ACCURACY_BUFFER_DEFAULT_METERS=320
VENUE_PRESENCE_ACCURACY_BUFFER_MAX_METERS=5000
VENUE_PRESENCE_ACCURACY_MULTIPLIER=1.5
VENUE_PRESENCE_FALSE_POSITIVE_WINDOW_MS=300000
VENUE_PRESENCE_DIAGNOSTICS_WINDOW_MINUTES=60
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ADS_BUCKET=advertisements
POLYMARKET_API_KEY=
POLYMARKET_API_URL=https://gamma-api.polymarket.com/markets
POLYMARKET_MARKET_LIMIT=20
POLYMARKET_SCAN_LIMIT=1000
ODDS_API_KEY=
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
ODDS_API_SPORT_KEYS=
ODDS_API_LOOKAHEAD_HOURS=168
ODDS_API_SCORES_DAYS=3
ODDS_API_CACHE_TTL_MS=120000
BALLDONTLIE_API_KEY=
BALLDONTLIE_API_BASE_URL=https://api.balldontlie.io
BALLDONTLIE_GAME_LOOKUP_WINDOW_DAYS=1
THESPORTSDB_API_KEY=
THESPORTSDB_API_BASE_URL=https://www.thesportsdb.com/api/v1/json
CRON_SECRET=
ADMIN_LOGIN_USERNAME=
ADMIN_LOGIN_PASSWORD=
GITHUB_TOKEN=
GITHUB_REPOSITORY=
GITHUB_BASE_BRANCH=main
GITHUB_EXPORT_DRAFT_PR=false
FANTASY_WINNER_POINTS=250
# Bypasses Category Blitz's <3-player scoring gate so a solo dev-server tester
# can see real grading/leaderboard behavior end-to-end. Never set in production.
CATEGORY_BLITZ_ALLOW_SOLO_SCORING=false

# ── Phase 6: domain split (apex → marketing /info, play. → the game) ──
# Master flag. Leave off (single-origin) until DNS for the play host is live.
NEXT_PUBLIC_DOMAIN_SPLIT_ENABLED=false
# Hosts (no scheme, no port). www. of the apex is treated as apex.
NEXT_PUBLIC_APEX_HOST=hightopchallenge.com
NEXT_PUBLIC_PLAY_HOST=play.hightopchallenge.com
# Absolute bases used to build cross-host links/redirects (default to https://<host>).
NEXT_PUBLIC_SITE_URL=https://hightopchallenge.com
NEXT_PUBLIC_PLAY_URL=https://play.hightopchallenge.com
# Parent-domain cookie scope so a player session survives apex ↔ play. navigation.
# Leave empty for host-only cookies (required for localhost/preview).
NEXT_PUBLIC_COOKIE_DOMAIN=

# ── Phase 8: partner welcome email (sent once, on Stripe checkout.session.completed) ──
# Resend API key. Leave empty to no-op (welcome email is skipped, billing sync is unaffected).
RESEND_API_KEY=
# Must be a domain verified in Resend (hightopchallenge.com already is). Falls back
# to a no-reply@ address on that domain if unset.
EMAIL_FROM_ADDRESS="Hightop Challenge <no-reply@hightopchallenge.com>"
